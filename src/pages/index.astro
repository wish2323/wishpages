---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const pages = [
	{
		slug: 'page1',
		title: '90 days making things',
		description: 'A record of consistently making new things. Side projects, extensions, tools.',
		href: '/page1/',
	},
	{
		slug: 'page2',
		title: 'projects',
		description: 'A collection of things I\'ve built.',
		href: '/page2/',
	},
];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<header>
			<nav>
				<span class="logo">wishpages</span>
				<a href="/page1/tags/">Tags</a>
			</nav>
		</header>

		<main>
			<section class="intro">
				<h1>wishpages</h1>
				<p class="tagline">A space for things I build and the stories behind them.</p>
				<p class="tagline">Tools, extensions, side projects — updated as they happen, not when they're perfect.</p>
			</section>

			<ul class="page-list">
				{
					pages.map((page) => (
						<li>
							<a href={page.href} class="page-card">
								<div class="card-left">
									<span class="card-title">{page.title}</span>
									<p class="card-desc">{page.description}</p>
								</div>
								<span class="card-arrow">→</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
		background: #fff;
		color: #111;
		margin: 0;
	}

	header {
		border-bottom: 1px solid #eee;
		padding: 0 1.5rem;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 680px;
		margin: 0 auto;
		height: 52px;
	}
	.logo {
		font-family: Georgia, serif;
		font-size: 1rem;
		font-weight: bold;
		letter-spacing: -0.01em;
		color: #111;
	}
	nav a {
		text-decoration: none;
		color: #555;
		font-size: 0.875rem;
	}
	nav a:hover { color: #111; }

	main {
		max-width: 680px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}

	.intro {
		margin-bottom: 3rem;
	}
	.intro h1 {
		font-size: 1.75rem;
		font-family: Georgia, serif;
		margin: 0 0 0.4rem 0;
		color: #111;
	}
	.tagline {
		color: #888;
		font-size: 0.9rem;
		margin: 0 0 0.2rem 0;
		line-height: 1.6;
	}
	.tagline:last-of-type {
		margin-bottom: 0;
	}

	.page-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.page-list li {
		border-top: 1px solid #f0f0f0;
	}
	.page-list li:last-child {
		border-bottom: 1px solid #f0f0f0;
	}

	.page-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem 0;
		text-decoration: none;
		color: inherit;
		gap: 1rem;
		transition: background 0.1s;
	}
	.page-card:hover {
		background: #fafafa;
		padding-left: 0.5rem;
		margin-left: -0.5rem;
		padding-right: 0.5rem;
		margin-right: -0.5rem;
		border-radius: 4px;
	}
	.card-left {
		flex: 1;
	}
	.card-title {
		display: block;
		font-size: 1rem;
		font-weight: 600;
		color: #111;
		margin-bottom: 0.35rem;
	}
	.card-desc {
		font-size: 0.875rem;
		color: #777;
		margin: 0;
		line-height: 1.5;
	}
	.card-arrow {
		font-size: 1rem;
		color: #ccc;
		flex-shrink: 0;
		transition: color 0.15s;
	}
	.page-card:hover .card-arrow {
		color: #555;
	}
</style>
