---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import HomeLink from '../../components/HomeLink.astro';

export async function getStaticPaths() {
	const projects = await getCollection('page2');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${project.data.title} · wishpages`}
			description={project.data.description}
		/>
	</head>
	<body>
		<header>
			<nav>
				<a href="/page2/" class="back">← projects</a>
				<HomeLink />
			</nav>
		</header>

		<main>
			<div class="project-header">
				<h1>{project.data.title}</h1>
				<p class="project-desc">{project.data.description}</p>
				<div class="tags">
					{(project.data.tags ?? []).map((tag) => (
						<span class="tag">#{tag}</span>
					))}
				</div>
			</div>

			<article class="prose">
				<Content />
				{project.data.marketplace && (
					<div class="marketplace-link">
						<a href={project.data.marketplace} target="_blank" rel="noopener">
							Install on VS Code Marketplace ↗
						</a>
					</div>
				)}
			</article>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
		background: #fff;
		color: #111;
		margin: 0;
	}
	header {
		border-bottom: 1px solid #eee;
		padding: 0 1.5rem;
	}
	nav {
		max-width: 680px;
		margin: 0 auto;
		height: 52px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		text-decoration: none;
		color: #555;
		font-size: 0.875rem;
	}
	nav a:hover { color: #111; }

	main {
		max-width: 680px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}

	.project-header {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid #f0f0f0;
	}
	h1 {
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0 0 0.5rem 0;
	}

	.project-desc {
		font-size: 0.9rem;
		color: #666;
		margin: 0 0 0.75rem 0;
		line-height: 1.5;
	}
	.tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.tag {
		font-size: 0.775rem;
		color: #bbb;
	}

	.prose {
		font-size: 0.975rem;
		line-height: 1.8;
		color: #333;
	}
	.prose :global(h2) {
		font-size: 1rem;
		font-weight: 700;
		margin: 2.5rem 0 0.75rem 0;
		color: #111;
	}
	.prose :global(h2:first-child) {
		margin-top: 0;
	}
	.prose :global(p) {
		margin: 0 0 1rem 0;
		color: #444;
	}
	.prose :global(ul) {
		margin: 0 0 1rem 0;
		padding-left: 1.25rem;
		color: #444;
	}
	.prose :global(li) {
		margin-bottom: 0.35rem;
	}
	.prose :global(code) {
		font-size: 0.875em;
		background: #f5f5f5;
		padding: 0.1em 0.35em;
		border-radius: 3px;
		color: #333;
	}
	.marketplace-link {
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid #f0f0f0;
	}
	.marketplace-link a {
		font-size: 0.875rem;
		color: #555;
		text-decoration: none;
		border: 1px solid #ddd;
		padding: 0.45rem 0.9rem;
		border-radius: 6px;
		transition: all 0.15s;
		display: inline-block;
	}
	.marketplace-link a:hover {
		color: #111;
		border-color: #111;
	}
</style>
